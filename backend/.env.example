# ---- Django ----
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
# Comma separated hostnames. Use * for quick testing only.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- CORS ----
# Comma separated origins allowed to call this API (the deployed React URL).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
# Option A: a single DATABASE_URL (this is what Render injects automatically).
# DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Option B: individual vars (used when DATABASE_URL is not set).
DB_ENGINE=django.db.backends.postgresql
DB_NAME=gate_intake
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# Zero-config escape hatch: set True to use a local SQLite file instead of Postgres.
USE_SQLITE_FALLBACK=False

# ---- OCR (Field Officer document extraction) ----
# Provider selects how uploaded scans are read into form fields:
#   ocrspace  (default) — free hosted OCR.space API; set OCRSPACE_API_KEY
#   tesseract           — local Tesseract binary (dev only; not on Render native)
#   mock                — canned sample values, no network (always works)
#   claude              — Anthropic vision (paid; needs the `anthropic` package + key)
OCR_PROVIDER=ocrspace
# Free demo key "helloworld" works for a few docs. Get a free key (no card) at
# https://ocr.space/ocrapi for higher limits.
OCRSPACE_API_KEY=helloworld
